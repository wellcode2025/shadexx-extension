{
  "manifest_version": 3,
  "name": "ShadeXX",
  "version": "0.1.0",
  "description": "Anonymous Web3 RPC proxy powered by the xx network cMixx mixnet",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ShadeXX"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "permissions": ["storage", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'",
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; object-src 'self'; connect-src 'self' chrome-extension://* blob: data: https: wss:"
  },
  "web_accessible_resources": [
    {
      "resources": ["sandbox.html", "sandbox.js", "xxdk-wasm/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
