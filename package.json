{
  "name": "shadexx-extension",
  "version": "0.1.0",
  "description": "Anonymous Web3 RPC proxy powered by the xx network cMixx mixnet",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:dev": "webpack --config webpack.config.js --mode development",
    "watch": "webpack --config webpack.config.js --watch --mode development",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "clean": "rm -rf dist/"
  },
  "keywords": [
    "web3",
    "privacy",
    "chrome-extension",
    "xx-network",
    "cmixx",
    "mixnet",
    "metamask",
    "rpc-proxy",
    "quantum-resistant"
  ],
  "author": "wellcode2025",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wellcode2025/shadexx-extension.git"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "xxdk-wasm": "^0.3.22"
  }
}
